      "production:check": "bun run release:check && bun run check:bundle && bun run check:docs && bun run pack:inspect",
      "check:bundle": "bun run check:bundle:lite && node scripts/check-bundle-size.mjs --entry src/tools/core/index.ts --max-kb 20 --label confused-ai/tools/core && node scripts/check-bundle-size.mjs --entry src/tools/search/index.ts --max-kb 80 --label confused-ai/tools/search && bun run check:bundle:root",
