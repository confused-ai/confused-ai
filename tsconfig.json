      "@confused-ai/tools/fs": ["./packages/tools-layer/tools/src/file-system.ts"],
      "@confused-ai/tools/browser": ["./packages/tools-layer/tools/src/browser.ts"],
      "@confused-ai/video": ["./packages/extensions/video/src/index.ts"],
      "@confused-ai/voice": ["./packages/extensions/voice/src/index.ts"],
      "@confused-ai/workflow": ["./packages/runtime/workflow/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "packages", "**/*.test.ts", "**/*.spec.ts"]
}
