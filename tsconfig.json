      "@confused-ai/production": ["./packages/platform/production/src/index.ts"],
      "@confused-ai/reasoning": ["./packages/runtime/reasoning/src/index.ts"],
      "@confused-ai/router": ["./packages/providers/router/src/index.ts"],
      "@confused-ai/scheduler": ["./packages/runtime/scheduler/src/index.ts"],
      "@confused-ai/sdk": ["./packages/developer/sdk/src/index.ts"],
      "@confused-ai/serve": ["./packages/platform/serve/src/index.ts"],
      "@confused-ai/session": ["./packages/state/session/src/index.ts"],
      "@confused-ai/shared": ["./packages/foundation/shared/src/index.ts"],
      "@confused-ai/storage": ["./packages/state/storage/src/index.ts"],
      "@confused-ai/test-utils": ["./packages/developer/test-utils/src/index.ts"],
      "@confused-ai/tools": ["./packages/tools-layer/tools/src/index.ts"],
