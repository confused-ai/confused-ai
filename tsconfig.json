{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["bun-types"],
    "paths": {
      "@confused-ai/adapter-redis": ["./packages/adapter-redis/src/index.ts"],
      "@confused-ai/agentic": ["./packages/agentic/src/index.ts"],
      "@confused-ai/artifacts": ["./packages/artifacts/src/index.ts"],
      "@confused-ai/background": ["./packages/background/src/index.ts"],
      "@confused-ai/cli": ["./packages/cli/src/index.ts"],
      "@confused-ai/compression": ["./packages/compression/src/index.ts"],
      "@confused-ai/config": ["./packages/config/src/index.ts"],
      "@confused-ai/context": ["./packages/context/src/index.ts"],
      "@confused-ai/contracts": ["./packages/contracts/src/index.ts"],
      "@confused-ai/core": ["./packages/core/src/index.ts"],
      "@confused-ai/db": ["./packages/db/src/index.ts"],
      "@confused-ai/eval": ["./packages/eval/src/index.ts"],
      "@confused-ai/execution": ["./packages/execution/src/index.ts"],
      "@confused-ai/graph": ["./packages/graph/src/index.ts"],
      "@confused-ai/guard": ["./packages/guard/src/index.ts"],
      "@confused-ai/guardrails": ["./packages/guardrails/src/index.ts"],
      "@confused-ai/knowledge": ["./packages/knowledge/src/index.ts"],
      "@confused-ai/learning": ["./packages/learning/src/index.ts"],
      "@confused-ai/memory": ["./packages/memory/src/index.ts"],
      "@confused-ai/models": ["./packages/models/src/index.ts"],
      "@confused-ai/observe": ["./packages/observe/src/index.ts"],
      "@confused-ai/orchestration": ["./packages/orchestration/src/index.ts"],
      "@confused-ai/planner": ["./packages/planner/src/index.ts"],
      "@confused-ai/playground": ["./packages/playground/src/index.ts"],
      "@confused-ai/plugins": ["./packages/plugins/src/index.ts"],
      "@confused-ai/production": ["./packages/production/src/index.ts"],
      "@confused-ai/reasoning": ["./packages/reasoning/src/index.ts"],
      "@confused-ai/router": ["./packages/router/src/index.ts"],
      "@confused-ai/scheduler": ["./packages/scheduler/src/index.ts"],
      "@confused-ai/sdk": ["./packages/sdk/src/index.ts"],
      "@confused-ai/serve": ["./packages/serve/src/index.ts"],
      "@confused-ai/session": ["./packages/session/src/index.ts"],
      "@confused-ai/shared": ["./packages/shared/src/index.ts"],
      "@confused-ai/storage": ["./packages/storage/src/index.ts"],
      "@confused-ai/test-utils": ["./packages/test-utils/src/index.ts"],
      "@confused-ai/tools": ["./packages/tools/src/index.ts"],
      "@confused-ai/tools/shell": ["./packages/tools/src/shell.ts"],
      "@confused-ai/tools/http": ["./packages/tools/src/http-client.ts"],
      "@confused-ai/tools/fs": ["./packages/tools/src/file-system.ts"],
      "@confused-ai/tools/browser": ["./packages/tools/src/browser.ts"],

      "@confused-ai/video": ["./packages/video/src/index.ts"],
      "@confused-ai/voice": ["./packages/voice/src/index.ts"],
      "@confused-ai/workflow": ["./packages/workflow/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "packages", "**/*.test.ts", "**/*.spec.ts"]
}
