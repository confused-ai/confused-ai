{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "allowSyntheticDefaultImports": true,
    "types": ["bun-types"],
    "paths": {
      "@confused-ai/adapter-redis": ["./packages/state/adapter-redis/src/index.ts"],
      "@confused-ai/agentic": ["./packages/runtime/agentic/src/index.ts"],
      "@confused-ai/artifacts": ["./packages/state/artifacts/src/index.ts"],
      "@confused-ai/background": ["./packages/runtime/background/src/index.ts"],
      "@confused-ai/cli": ["./packages/developer/cli/src/index.ts"],
      "@confused-ai/compression": ["./packages/platform/compression/src/index.ts"],
      "@confused-ai/config": ["./packages/platform/config/src/index.ts"],
      "@confused-ai/context": ["./packages/platform/context/src/index.ts"],
      "@confused-ai/contracts": ["./packages/foundation/contracts/src/index.ts"],
      "@confused-ai/core": ["./packages/runtime/core/src/index.ts"],
      "@confused-ai/db": ["./packages/state/db/src/index.ts"],
      "@confused-ai/eval": ["./packages/platform/eval/src/index.ts"],
      "@confused-ai/execution": ["./packages/runtime/execution/src/index.ts"],
      "@confused-ai/graph": ["./packages/runtime/graph/src/index.ts"],
      "@confused-ai/guard": ["./packages/platform/guard/src/index.ts"],
      "@confused-ai/guardrails": ["./packages/platform/guardrails/src/index.ts"],
      "@confused-ai/knowledge": ["./packages/state/knowledge/src/index.ts"],
      "@confused-ai/learning": ["./packages/state/learning/src/index.ts"],
      "@confused-ai/memory": ["./packages/state/memory/src/index.ts"],
      "@confused-ai/models": ["./packages/providers/models/src/index.ts"],
      "@confused-ai/observe": ["./packages/platform/observe/src/index.ts"],
      "@confused-ai/orchestration": ["./packages/runtime/orchestration/src/index.ts"],
      "@confused-ai/planner": ["./packages/runtime/planner/src/index.ts"],
