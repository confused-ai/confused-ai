{
  "name": "@confused-ai/tools",
  "version": "0.1.0",
  "description": "Built-in tool set for confused-ai. Built-in Node.js tools are eager; heavy-dep tools (browser, DB) are lazy.",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./http": {
      "types": "./dist/http-client.d.ts",
      "import": "./dist/http-client.js",
      "require": "./dist/http-client.cjs"
    },
    "./fs": {
      "types": "./dist/file-system.d.ts",
      "import": "./dist/file-system.js",
      "require": "./dist/file-system.cjs"
    },
    "./shell": {
      "types": "./dist/shell.d.ts",
      "import": "./dist/shell.js",
      "require": "./dist/shell.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "@confused-ai/contracts": "*",
    "@confused-ai/core": "*",
    "@confused-ai/shared": "*",
    "zod": "^3.0.0"
  },
  "peerDependencies": {
    "playwright": ">=1.0.0",
    "duck-duck-scrape": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    },
    "duck-duck-scrape": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "license": "MIT",
  "module": "./dist/index.js"
}
