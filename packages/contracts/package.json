{
  "name": "@confused-ai/contracts",
  "version": "0.1.0",
  "description": "Zero-dependency interfaces and types shared across confused-ai packages.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./errors": "./src/errors.ts",
    "./result": "./src/result.ts",
    "./adapters": "./src/adapters.ts"
  },
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./errors": {
        "types": "./dist/errors.d.ts",
        "import": "./dist/errors.js",
        "require": "./dist/errors.cjs"
      },
      "./result": {
        "types": "./dist/result.d.ts",
        "import": "./dist/result.js",
        "require": "./dist/result.cjs"
      },
      "./adapters": {
        "types": "./dist/adapters.d.ts",
        "import": "./dist/adapters.js",
        "require": "./dist/adapters.cjs"
      }
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src --max-warnings 0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "license": "MIT"
}
