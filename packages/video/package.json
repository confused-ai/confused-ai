{
  "name": "@confused-ai/video",
  "version": "0.1.0",
  "description": "Video processing module: frame extraction, overlays, synthesis with FFmpeg and Pexels",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "peerDependencies": {
    "fluent-ffmpeg": ">=2.1.0",
    "@ffmpeg-installer/ffmpeg": ">=1.1.0",
    "openai": ">=4.0.0",
    "pexels": ">=1.4.0"
  },
  "peerDependenciesMeta": {
    "fluent-ffmpeg": {
      "optional": true
    },
    "@ffmpeg-installer/ffmpeg": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "pexels": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist"
  ],
  "module": "./dist/index.js"
}
