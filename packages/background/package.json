{
  "name": "@confused-ai/background",
  "version": "0.1.0",
  "description": "Background queue adapters for AI agent hooks: BullMQ, Kafka, RabbitMQ, Redis, SQS, in-memory",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "peerDependencies": {
    "bullmq": ">=4.0.0",
    "kafkajs": ">=2.0.0",
    "amqplib": ">=0.10.0",
    "ioredis": ">=5.0.0",
    "@aws-sdk/client-sqs": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "bullmq": { "optional": true },
    "kafkajs": { "optional": true },
    "amqplib": { "optional": true },
    "ioredis": { "optional": true },
    "@aws-sdk/client-sqs": { "optional": true }
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "*"
  }
}
