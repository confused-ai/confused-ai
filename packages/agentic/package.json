{
  "name": "@confused-ai/agentic",
  "version": "0.1.0",
  "description": "ReAct-style agentic loop with tool dispatch, guardrails, and human-in-the-loop",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@confused-ai/core": "*",
    "@confused-ai/guard": "*",
    "@confused-ai/guardrails": "*",
    "@confused-ai/observe": "*",
    "@confused-ai/shared": "*",
    "zod": "^3.0.0"
  },
  "peerDependencies": {
    "@confused-ai/compression": "*",
    "@confused-ai/knowledge": "*",
    "@confused-ai/production": "*",
    "@confused-ai/reasoning": "*",
    "@opentelemetry/api": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@confused-ai/compression": {
      "optional": true
    },
    "@confused-ai/knowledge": {
      "optional": true
    },
    "@confused-ai/production": {
      "optional": true
    },
    "@confused-ai/reasoning": {
      "optional": true
    },
    "@opentelemetry/api": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "*"
  },
  "files": [
    "dist"
  ],
  "module": "./dist/index.js"
}
