{
  "name": "@confused-ai/serve",
  "version": "0.1.0",
  "description": "HTTP runtime utilities: request validation, auth, lifecycle.",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@confused-ai/contracts": "*",
    "@confused-ai/production": "*"
  },
  "peerDependencies": {
    "zod": ">=3.22.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "zod": "^3.23.8"
  },
  "license": "MIT",
  "module": "./dist/index.js"
}
