{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    // Override strictness: graph engine was authored under root tsconfig (no exactOptionalPropertyTypes)
    // TODO: fix engine.ts + types.ts to be fully strict (Wave 3 follow-up)
    "exactOptionalPropertyTypes": false,
    "noPropertyAccessFromIndexSignature": false,
    "noUncheckedIndexedAccess": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
